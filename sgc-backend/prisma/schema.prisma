generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Bank {
  id         String      @id @default(cuid())
  name       String
  isArchived Boolean     @default(false)
  createdAt  DateTime    @default(now())
  personnel  Personnel[]
}

model PensionFund {
  id           String      @id @default(cuid())
  name         String
  discountRate Float
  isArchived   Boolean     @default(false)
  createdAt    DateTime    @default(now())
  personnel    Personnel[]
}

model HealthProvider {
  id           String      @id @default(cuid())
  name         String
  type         String
  discountRate Float
  isArchived   Boolean     @default(false)
  createdAt    DateTime    @default(now())
  personnel    Personnel[]
}

model UnitType {
  id                 String              @id @default(cuid())
  name               String
  baseCommonExpense  Float
  isArchived         Boolean             @default(false)
  createdAt          DateTime            @default(now())
  commonExpenseRules CommonExpenseRule[]
  departments        Department[]
}

model Tower {
  id          String       @id @default(cuid())
  name        String
  isArchived  Boolean      @default(false)
  createdAt   DateTime     @default(now())
  departments Department[]
}

model Department {
  id                    String                 @id @default(cuid())
  towerId               String?
  number                String
  unitTypeId            String?
  propertyRole          String?
  m2                    Float?
  waterClientId         String?
  electricityClientId   String?
  gasClientId           String?
  ownerId               String?
  residentId            String?
  isArchived            Boolean                @default(false)
  createdAt             DateTime               @default(now())
  commonExpensePayments CommonExpensePayment[]
  correspondence        Correspondence[]
  resident              Resident?              @relation(fields: [residentId], references: [id])
  owner                 Owner?                 @relation(fields: [ownerId], references: [id])
  unitType              UnitType?              @relation(fields: [unitTypeId], references: [id])
  tower                 Tower?                 @relation(fields: [towerId], references: [id])
  parking               Parking[]
}

model Owner {
  id          String       @id @default(cuid())
  names       String
  lastNames   String
  dni         String       @unique
  phone       String
  email       String
  notes       String?
  status      String       @default("active")
  isArchived  Boolean      @default(false)
  createdAt   DateTime     @default(now())
  departments Department[]
}

model Resident {
  id          String       @id @default(cuid())
  names       String
  lastNames   String
  dni         String       @unique
  phone       String
  email       String
  familyCount Int          @default(1)
  hasPets     Boolean      @default(false)
  notes       String?
  isTenant    Boolean      @default(false)
  rentAmount  Float?
  status      String       @default("active")
  isArchived  Boolean      @default(false)
  createdAt   DateTime     @default(now())
  departments Department[]
}

model Personnel {
  id                          String          @id @default(cuid())
  names                       String
  lastNames                   String
  dni                         String          @unique
  phone                       String?
  email                       String?
  photo                       String?
  isHonorary                  Boolean         @default(false)
  bankId                      String?
  accountNumber               String?
  baseSalary                  Float
  vacationDays                Int             @default(0)
  healthProviderId            String?
  hasComplementaryInsurance   Boolean         @default(false)
  complementaryInsuranceType  String?
  complementaryInsuranceValue Float           @default(0)
  pensionFundId               String?
  hasAPV                      Boolean         @default(false)
  apvType                     String?
  apvValue                    Float           @default(0)
  jornadaGroupId              String?
  address                     String
  position                    String?
  medicalInfo                 String?
  contractType                String          @default("indefinido")
  hasEmergencyContact         Boolean         @default(false)
  emergencyContactJson        String?
  assignedArticlesJson        String?
  status                      String          @default("active")
  isArchived                  Boolean         @default(false)
  createdAt                   DateTime        @default(now())
  jornadaGroup                JornadaGroup?   @relation(fields: [jornadaGroupId], references: [id])
  pensionFund                 PensionFund?    @relation(fields: [pensionFundId], references: [id])
  healthProvider              HealthProvider? @relation(fields: [healthProviderId], references: [id])
  bank                        Bank?           @relation(fields: [bankId], references: [id])
}

model JornadaGroup {
  id           String      @id @default(cuid())
  name         String
  description  String?
  startTime    String
  endTime      String
  workDays     String
  schedules    String?
  breakMinutes Int         @default(0)
  isActive     Boolean     @default(true)
  isArchived   Boolean     @default(false)
  createdAt    DateTime    @default(now())
  personnel    Personnel[]
}

model IPCProjection {
  id            String   @id @default(cuid())
  name          String
  ipcRate       Float
  ponderadoRate Float    @default(0)
  description   String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
}

model InfrastructureItem {
  id          String   @id @default(cuid())
  name        String
  description String?
  isMandatory Boolean  @default(false)
  isArchived  Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model EquipmentItem {
  id          String   @id @default(cuid())
  name        String
  description String?
  isMandatory Boolean  @default(false)
  isArchived  Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Article {
  id                    String   @id @default(cuid())
  name                  String
  description           String?
  category              String
  unit                  String   @default("unidades")
  price                 Float    @default(0)
  stock                 Int      @default(0)
  minStock              Int      @default(0)
  isActive              Boolean  @default(true)
  allowPersonnelRequest Boolean  @default(false)
  isArchived            Boolean  @default(false)
  createdAt             DateTime @default(now())
}

model Correspondence {
  id           String     @id @default(cuid())
  folio        String     @unique
  departmentId String
  towerId      String?
  type         String
  addressee    String
  status       String     @default("pending")
  receivedAt   DateTime?  @default(now())
  deliveredAt  DateTime?
  createdAt    DateTime   @default(now())
  department   Department @relation(fields: [departmentId], references: [id])
}

model Parking {
  id            String      @id @default(cuid())
  number        String
  location      String?
  isHandicapped Boolean     @default(false)
  isArchived    Boolean     @default(false)
  departmentId  String?
  createdAt     DateTime    @default(now())
  department    Department? @relation(fields: [departmentId], references: [id])
}

model CommonExpenseRule {
  id            String    @id @default(cuid())
  unitTypeId    String?
  amount        Float
  effectiveFrom DateTime
  description   String?
  isArchived    Boolean   @default(false)
  createdAt     DateTime  @default(now())
  unitType      UnitType? @relation(fields: [unitTypeId], references: [id])
}

model CommonExpensePayment {
  id                    String     @id @default(cuid())
  departmentId          String
  periodMonth           Int
  periodYear            Int
  amountPaid            Float
  paymentDate           DateTime   @default(now())
  status                String     @default("paid")
  paymentMethod         String?
  receiptFolio          String?    @unique
  evidenceImage         String?
  notes                 String?
  isElectronic          Boolean    @default(true)
  createdAt             DateTime   @default(now())
  fundContributionsJson String?
  department            Department @relation(fields: [departmentId], references: [id])
}

model SpecialFund {
  id                 String   @id @default(cuid())
  name               String
  description        String
  type               String
  totalAmountPerUnit Float
  totalProjectAmount Float?
  deadline           String?
  isActive           Boolean  @default(true)
  isArchived         Boolean  @default(false)
  unitConfigsJson    String?
  expensesJson       String?
  createdAt          DateTime @default(now())
}

model EmergencyNumber {
  id          String   @id @default(cuid())
  category    String
  name        String
  phone       String
  description String?
  webUrl      String?
  isArchived  Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model CommunicationTemplate {
  id        String   @id @default(cuid())
  name      String
  subject   String
  message   String   @default("")
  type      String   @default("general")
  createdAt DateTime @default(now())
}

model CommunicationHistory {
  id            String   @id @default(cuid())
  subject       String
  message       String   @default("")
  recipients    String
  senderId      String
  targetFilter  String
  attachmentUrl String?
  createdAt     DateTime @default(now())
}

model SystemParameter {
  id          String   @id @default(cuid())
  type        String
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Holiday {
  id          String   @id @default(cuid())
  date        DateTime
  description String
  isArchived  Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Afc {
  id                 String   @id @default(cuid())
  name               String   @default("AFC")
  fixedTermRate      Float
  indefiniteTermRate Float
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
}

model SystemSettings {
  id                  String   @id @default(cuid())
  systemName          String   @default("Administración GAG")
  systemIcon          String   @default("G")
  systemLogo          String?
  systemFavicon       String?
  cameraBackupDays    Int      @default(7)
  darkMode            Boolean  @default(false)
  theme               String   @default("light")
  adminName           String   @default("")
  adminRut            String   @default("")
  condoRut            String   @default("")
  condoAddress        String   @default("")
  adminPhone          String   @default("")
  adminSignature      String?
  deletionPassword    String   @default("")
  vacationAccrualRate Float    @default(1.25)
  paymentDeadlineDay  Int      @default(5)
  maxArrearsMonths    Int      @default(3)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}
