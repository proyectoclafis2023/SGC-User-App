// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Bank {
  id         String   @id @default(cuid())
  name       String
  isArchived Boolean  @default(false)
  createdAt  DateTime @default(now())
  personnel  Personnel[]
}

model PensionFund {
  id           String   @id @default(cuid())
  name         String
  discountRate Float
  isArchived   Boolean  @default(false)
  createdAt    DateTime @default(now())
  personnel    Personnel[]
}

model HealthProvider {
  id           String   @id @default(cuid())
  name         String
  type         String   // 'fonasa' or 'isapre'
  discountRate Float
  isArchived   Boolean  @default(false)
  createdAt    DateTime @default(now())
  personnel    Personnel[]
}

model UnitType {
  id                 String       @id @default(cuid())
  name               String
  baseCommonExpense Float
  isArchived         Boolean      @default(false)
  createdAt          DateTime     @default(now())
  departments        Department[]
  commonExpenseRules CommonExpenseRule[]
}

model Tower {
  id         String       @id @default(cuid())
  name       String
  isArchived Boolean      @default(false)
  createdAt  DateTime     @default(now())
  departments Department[]
}

model Department {
  id                  String   @id @default(cuid())
  towerId             String?
  tower               Tower?   @relation(fields: [towerId], references: [id])
  number              String
  unitTypeId          String?
  unitType            UnitType? @relation(fields: [unitTypeId], references: [id])
  propertyRole        String?
  m2                  Float?
  waterClientId       String?
  electricityClientId String?
  gasClientId         String?
  ownerId             String?
  owner               Owner?   @relation(fields: [ownerId], references: [id])
  residentId          String?
  resident            Resident? @relation(fields: [residentId], references: [id])
  isArchived          Boolean  @default(false)
  createdAt           DateTime @default(now())
  correspondence      Correspondence[]
  parking             Parking[]
  commonExpensePayments CommonExpensePayment[]
}

model Owner {
  id          String       @id @default(cuid())
  names       String
  lastNames   String
  dni         String       @unique
  phone       String
  email       String
  notes       String?
  status      String       @default("active")
  isArchived  Boolean      @default(false)
  createdAt   DateTime     @default(now())
  departments Department[]
}

model Resident {
  id            String       @id @default(cuid())
  names         String
  lastNames     String
  dni           String       @unique
  phone         String
  email         String
  familyCount   Int          @default(1)
  hasPets       Boolean      @default(false)
  notes         String?
  isTenant      Boolean      @default(false)
  rentAmount    Float?
  status        String       @default("active")
  isArchived    Boolean      @default(false)
  createdAt     DateTime     @default(now())
  departments   Department[]
}

model Personnel {
  id                String       @id @default(cuid())
  names             String
  lastNames         String
  dni               String       @unique
  phone             String?
  email             String?
  isHonorary        Boolean      @default(false)
  bankId            String?
  bank              Bank?        @relation(fields: [bankId], references: [id])
  accountNumber     String?
  baseSalary        Float
  vacationDays      Int          @default(0)
  healthProviderId  String?
  healthProvider    HealthProvider? @relation(fields: [healthProviderId], references: [id])
  pensionFundId     String?
  pensionFund       PensionFund? @relation(fields: [pensionFundId], references: [id])
  address           String
  position          String?
  status            String       @default("active")
  isArchived        Boolean      @default(false)
  createdAt         DateTime     @default(now())
}

model Article {
  id          String   @id @default(cuid())
  name        String
  description String?
  category    String   // 'EPP', 'Aseo', 'Oficina', 'otro'
  price       Float    @default(0)
  stock       Int      @default(0)
  minStock    Int      @default(0)
  isActive    Boolean  @default(true)
  isArchived  Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Correspondence {
  id             String     @id @default(cuid())
  folio          String     @unique
  departmentId   String
  department     Department @relation(fields: [departmentId], references: [id])
  towerId        String?
  type           String     // 'package', 'letter', etc.
  addressee      String
  status         String     @default("pending") // 'pending', 'received', 'notified', 'delivered'
  receivedAt     DateTime?  @default(now())
  deliveredAt    DateTime?
  createdAt      DateTime   @default(now())
}

model Parking {
  id            String     @id @default(cuid())
  number        String
  location      String?
  isHandicapped Boolean    @default(false)
  isArchived    Boolean    @default(false)
  departmentId  String?
  department    Department? @relation(fields: [departmentId], references: [id])
  createdAt     DateTime   @default(now())
}

model CommonExpenseRule {
  id                String       @id @default(cuid())
  unitTypeId        String?
  unitType          UnitType?    @relation(fields: [unitTypeId], references: [id])
  amount            Float
  effectiveFrom     DateTime
  description       String?
  isArchived        Boolean      @default(false)
  createdAt         DateTime     @default(now())
}

model CommonExpensePayment {
  id                String       @id @default(cuid())
  departmentId      String
  department        Department   @relation(fields: [departmentId], references: [id])
  periodMonth       Int
  periodYear        Int
  amountPaid        Float
  paymentDate       DateTime     @default(now())
  status            String       @default("paid") // 'paid', 'pending', 'overdue'
  paymentMethod     String?
  receiptFolio      String?      @unique
  evidenceImage     String?      // Captura del documento manual
  notes             String?
  isElectronic      Boolean      @default(true)  // si es comprobante electrónico o captura manual
  fundContributionsJson String?  // [ { "fundId": "...", "amount": 100 } ]
  createdAt         DateTime     @default(now())
}

model SpecialFund {
  id                  String   @id @default(cuid())
  name                String
  description         String
  type                String   // 'reserve', 'extraordinary'
  totalAmountPerUnit  Float
  totalProjectAmount  Float?
  deadline            String?
  isActive            Boolean  @default(true)
  isArchived          Boolean  @default(false)
  unitConfigsJson     String?  // [ { "unitTypeId": "...", "calculationType": "fixed", "value": 100, "isExempt": false } ]
  expensesJson        String?  // [ { "id": "...", "amount": 100, "description": "...", "date": "..." } ]
  createdAt           DateTime @default(now())
}
model EmergencyNumber {
  id          String   @id @default(cuid())
  category    String   // 'SEGURIDAD', 'EMERGENCIA', etc.
  name        String
  phone       String
  description String?
  webUrl      String?
  isArchived  Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model CommunicationTemplate {
  id        String   @id @default(cuid())
  name      String
  subject   String
  message   String   @default("")
  type      String   @default("general") // 'mora', 'asamblea', 'comunicado', etc.
  createdAt DateTime @default(now())
}

model CommunicationHistory {
  id            String   @id @default(cuid())
  subject       String
  message       String   @default("")
  recipients    String   // JSON string of email addresses
  senderId      String
  targetFilter  String   // readable description of the filter used
  attachmentUrl String?
  createdAt     DateTime @default(now())
}

